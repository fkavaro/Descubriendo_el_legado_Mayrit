                    <ui:VisualElement style="flex-grow: 1; justify-content: center; width: 300px;">
                        <ui:Label text="Orientar cámara" name="Subheader" class="subHeader" style="margin-top: 0; -unity-text-align: upper-center;"/>
                        <ui:Label text="Mantén pulsado el botón izquierdo del ratón y muévelo." name="Text" class="text"/>
