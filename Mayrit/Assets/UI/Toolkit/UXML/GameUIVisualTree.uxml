                <ui:VisualElement name="Orbit" style="position: absolute; top: auto; left: auto; right: auto; bottom: 100px; align-self: center; flex-direction: row; justify-content: center; display: none; width: 500px; padding-top: 20px; padding-right: 20px; padding-bottom: 20px; padding-left: 20px;">
