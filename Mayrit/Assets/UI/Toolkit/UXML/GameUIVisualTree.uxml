                    <ui:Label text="Para orientar la cámara mueve el ratón. Para moverte pulsa las teclas W,A,S o D. Irás más rápido si además pulsas la tecla SHIFT. Para saltar pulsa la tecla SPACE. &#10;Para volver a la cámara aérea pulsa la tecla TAB." name="Text" class="text" style="-unity-text-align: middle-center;"/>
                    <ui:Image source="project://database/Assets/Imports/External/European%20Forests%20-%20Realistic%20Trees/Source/Textures/Ash/Ash_Bark.png?fileID=2800000&amp;guid=155b3dfe4ba28214384025db4839ab67&amp;type=3#Ash_Bark" name="Image" style="margin-top: 10px; display: none;"/>
                </ui:VisualElement>
                <ui:VisualElement name="PointOfInterestCompass" style="position: absolute; top: auto; left: auto; right: 230px; bottom: 17px; align-self: center; flex-direction: column; justify-content: center; display: none; width: 500px; padding-top: 20px; padding-right: 20px; padding-bottom: 20px; padding-left: 20px;">
                    <ui:VisualElement name="Bg" class="tutorialBlurBg" style="flex-grow: 1; display: flex;"/>
                    <ui:Label text="Alcanzar las paradas del tour" name="Subheader" class="subHeader" style="margin-top: 0; -unity-text-align: upper-center; margin-right: 0; margin-bottom: 0; margin-left: 0;"/>
                    <ui:Label text="Sigue la dirección de la brújula hacia la siguiente  parada. Completarás el tour tras visitarlas todas." name="Text" class="text" style="-unity-text-align: middle-center;"/>
                    <ui:Image source="project://database/Assets/UI/Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=-1087164816274819069&amp;guid=2196264947afaa74a8b087d37850e618&amp;type=3#arrow-right@2x" name="Image" tint-color="rgb(220, 220, 220)" scale-mode="StretchToFill" style="display: flex; width: 80px; align-self: center; position: absolute; right: -70px; top: 35px; bottom: auto; height: 110px;"/>
                </ui:VisualElement>
