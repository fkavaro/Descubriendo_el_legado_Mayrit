            <ui:Label text="Más información" class="header" style="flex-shrink: 1; flex-grow: 1; -unity-text-align: middle-left; margin-top: 30px; margin-right: 30px; margin-bottom: 40px; margin-left: 30px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
            <ui:TabView style="flex-grow: 1;">
                <ui:Tab label="Marco histórico" name="History">
                    <ui:ScrollView>
