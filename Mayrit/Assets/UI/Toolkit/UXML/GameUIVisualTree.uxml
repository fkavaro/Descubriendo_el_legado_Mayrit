        <ui:VisualElement name="PlayerHUD" enabled="true" picking-mode="Ignore" style="justify-content: space-between; align-self: stretch; flex-grow: 1; flex-direction: row; display: none; position: absolute; top: 0; left: 0; right: 0; bottom: 0; margin-top: 30px; margin-right: 30px; margin-bottom: 30px; margin-left: 30px;">
