                    <ui:Slider label="Música" value="42" high-value="1" name="MusicVolumeSlider" fill="true" style="color: rgb(255, 255, 255); font-size: 20px; margin-top: 5px; margin-right: 10px; margin-bottom: 10px; margin-left: 10px;"/>
