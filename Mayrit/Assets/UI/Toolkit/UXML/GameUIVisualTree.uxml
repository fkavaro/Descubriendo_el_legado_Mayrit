                <ui:VisualElement name="ShowCharacterInfo" style="position: absolute; align-self: center; flex-direction: column; justify-content: flex-start; display: none; padding-top: 20px; padding-right: 20px; padding-bottom: 20px; padding-left: 20px; align-items: center; bottom: 120px; width: 500px;">
