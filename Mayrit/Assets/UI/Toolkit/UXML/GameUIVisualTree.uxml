    <ui:VisualElement name="ContextualPanel" class="contextualPanel" style="display: none; align-self: flex-end; position: absolute; right: 0; top: 0; bottom: 0; padding-right: 50px; padding-bottom: 40px;">
        <ui:VisualElement name="Bg" class="contextualPanelBlurBg"/>
        <ui:VisualElement name="InformationArea" style="display: flex; flex-grow: 1;">
            <ui:VisualElement name="UpperArea" picking-mode="Ignore" style="flex-direction: row-reverse; flex-grow: 0; flex-shrink: 0; margin-bottom: 15px; margin-right: 30px;">
                <ui:VisualElement name="Headers" style="flex-grow: 1;">
                    <ui:Label name="Header" text="*Mezquita aljama" class="header"/>
                    <ui:Label name="SubHeader" text="*Segunda mitad s.IX" class="subHeader" style="flex-grow: 1; display: flex;"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:ScrollView focusable="false" horizontal-scroller-visibility="Hidden" vertical-scroller-visibility="Auto" enabled="true" mode="Vertical" name="ScrollView" class="scrollable-section scrollable" style="display: flex;">
                <ui:VisualElement name="DisclaimerArea" class="section" style="border-left-color: rgba(255, 215, 0, 0.59); border-right-color: rgba(255, 215, 0, 0.59); border-top-color: rgba(255, 215, 0, 0.59); border-bottom-color: rgba(255, 215, 0, 0.59); margin-bottom: 20px;">
                    <ui:Label text="Disclaimer" class="subHeader" style="color: rgb(255, 215, 0);"/>
                    <ui:Label text="Este modelo 3D no es representativo." name="Disclaimer" class="text"/>
                </ui:VisualElement>
                <ui:VisualElement name="GlosaryArea" class="section" style="margin-bottom: 20px;">
                    <ui:Label text="Glosario" class="subHeader"/>
                    <ui:VisualElement name="GlosaryList" style="flex-grow: 1;">
                        <ui:Label text="Definición de palabra" class="text"/>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="DescriptionArea" class="section" style="display: flex; margin-bottom: 20px;">
                    <ui:Label text="Descripción" class="subHeader"/>
                    <ui:Label text="*Era la principal, la de la oración del viernes, y por la que la población tenía carácter de medina/ciudad. Sobre esta se levantó la Iglesia de Santa María de la Almudena, derribada para ensanchar la calle Mayor, en el entorno de las actuales calles Mayor y Bailén, en la zona que hoy conocemos como Las Vistillas.  Tenía cinco naves perpendiculares al muro de la alquibla (el que da a la Meca), con su característico mihrab u hornacina decorada, donde después se abrió la entrada principal de la iglesia. &#10;En su parte opuesta, es decir, noroeste, había un patio con su alminar, que dio lugar después al campanario cristiano. Sería una torre cuadrada con el cuerpo superior retranqueado que suelen tener las mezquitas del occidente islámico. Estaría rematada por un ŷamur.  En sus conquistas, los cristianos acostumbraban a consagrar sus parroquias principales bajo la titulación de Santa María como signo de protección cuando antes había sido mezquita." name="Description" class="text"/>
                    <ui:VisualElement name="ImageArea" style="flex-grow: 1; display: flex;">
                        <ui:VisualElement name="Image" style="flex-grow: 0; background-image: url(&quot;project://database/Assets/Imports/Data%20images/Iglesia%20de%20Santa%20Maria.jpg?fileID=2800000&amp;guid=30e84b69ac325604a9737e73910905af&amp;type=3#Iglesia de Santa Maria&quot;); height: 300px; width: 100%; flex-shrink: 0; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px; margin-top: 20px; margin-bottom: 20px; display: flex;"/>
                        <ui:Label text="Pie de foto" name="Caption" class="text"/>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="ConservationArea" class="section" style="margin-bottom: 20px;">
                    <ui:Label text="Conservación" class="subHeader" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                    <ui:Label text="Conservacoión en la actualidad" name="Conservation" class="text"/>
                </ui:VisualElement>
                <ui:VisualElement name="SourcesArea" class="section">
                    <ui:Label text="Fuentes historiográficas" class="subHeader" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                    <ui:VisualElement name="SourcesList" style="flex-grow: 1;">
