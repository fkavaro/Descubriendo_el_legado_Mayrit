        <ui:VisualElement name="ContextualPanel" style="width: 35%; background-color: rgba(0, 0, 0, 0.78); border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px; display: none; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; position: absolute; top: 0; right: 0; bottom: 0; flex-grow: 1; justify-content: space-between; visibility: visible;">
            <ui:VisualElement name="InformationArea" style="flex-grow: 1;">
                <ui:VisualElement name="UpperArea" style="flex-direction: row-reverse; flex-grow: 0; flex-shrink: 0;">
                    <ui:Button text="X" name="CloseButton" class="button closeButton" style="align-self: flex-start; position: relative;"/>
                    <ui:VisualElement name="Headers" style="flex-grow: 1; margin-top: 10px;">
                        <ui:Label name="Header" text="*Mezquita aljama" class="header" style="margin-top: 10px; margin-right: 10px; margin-bottom: 10px; margin-left: 10px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-grow: 1; -unity-text-align: middle-center;"/>
                        <ui:Label name="SubHeader" text="*Segunda mitad s.IX" class="subHeader" style="margin-top: 10px; margin-right: 10px; margin-bottom: 10px; margin-left: 10px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; flex-grow: 1; display: flex; -unity-text-align: middle-center;"/>
                    </ui:VisualElement>
                    <ui:VisualElement name="Icon" style="flex-shrink: 0; width: 80px; height: 80px; margin-top: 15px; margin-right: 15px; margin-bottom: 15px; margin-left: 15px; background-image: url(&quot;project://database/Assets/UI/Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=6936960519852013934&amp;guid=2196264947afaa74a8b087d37850e618&amp;type=3#arrow-up@2x&quot;);"/>
                </ui:VisualElement>
                <ui:ScrollView focusable="false" horizontal-scroller-visibility="Hidden" vertical-scroller-visibility="Auto" enabled="true" mode="Vertical" name="ScrollView" style="display: flex; margin-top: 20px; margin-right: 20px; margin-bottom: 20px; margin-left: 20px;">
                    <ui:VisualElement name="DescriptionArea" style="flex-grow: 1; margin-top: 0; margin-right: 20px; margin-bottom: 0; margin-left: 20px;">
                        <ui:Label text="*Era la principal, la de la oración del viernes, y por la que la población tenía carácter de medina/ciudad. Sobre esta se levantó la Iglesia de Santa María de la Almudena, derribada para ensanchar la calle Mayor, en el entorno de las actuales calles Mayor y Bailén, en la zona que hoy conocemos como Las Vistillas.  Tenía cinco naves perpendiculares al muro de la alquibla (el que da a la Meca), con su característico mihrab u hornacina decorada, donde después se abrió la entrada principal de la iglesia. En su parte opuesta, es decir, noroeste, había un patio con su alminar, que dio lugar después al campanario cristiano. Sería una torre cuadrada con el cuerpo superior retranqueado que suelen tener las mezquitas del occidente islámico. Estaría rematada por un ŷamur.  En sus conquistas, los cristianos acostumbraban a consagrar sus parroquias principales bajo la titulación de Santa María como signo de protección cuando antes había sido mezquita." name="Description" style="-unity-text-align: upper-center; font-size: 25px; color: rgb(255, 255, 255); text-overflow: clip; white-space: normal; -unity-paragraph-spacing: 60px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;"/>
                        <ui:VisualElement name="ImageArea" style="flex-grow: 1; display: flex;">
                            <ui:VisualElement name="Image" style="flex-grow: 0; background-image: url(&quot;project://database/Assets/Imports/External/Rocks%20and%20Boulders%202/Source/Textures/Rockdetail1.tif?fileID=2800000&amp;guid=19b818e26c2922a488c06b1fbdae5df3&amp;type=3#Rockdetail1&quot;); height: 300px; width: 550px; flex-shrink: 0; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px; margin-top: 20px; margin-bottom: 20px; display: flex;"/>
                            <ui:Label text="Pie de foto" name="Caption" style="-unity-text-align: upper-center; font-size: 25px; color: rgb(255, 255, 255); text-overflow: clip; white-space: normal; -unity-paragraph-spacing: 60px; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; display: flex;"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:ScrollView>
            </ui:VisualElement>
