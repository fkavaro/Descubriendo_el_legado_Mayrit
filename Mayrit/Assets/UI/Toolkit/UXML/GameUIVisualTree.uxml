                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="ZoomIn" style="align-self: center; flex-direction: row; justify-content: center; display: none; position: absolute; width: 500px; padding-top: 20px; padding-right: 20px; padding-bottom: 20px; padding-left: 20px; left: auto; bottom: 100px;">
                    <ui:VisualElement name="Bg" class="tutorialBlurBg" style="flex-grow: 1; display: flex;"/>
                    <ui:VisualElement style="flex-grow: 1; justify-content: center; width: 300px;">
                        <ui:Label text="Acercar cámara" name="Subheader" class="subHeader" style="margin-top: 0; -unity-text-align: upper-center;"/>
                        <ui:Label text="Deliza hacia arriba la rueda del ratón." name="Text" class="text" style="-unity-text-align: middle-center;"/>
                    </ui:VisualElement>
