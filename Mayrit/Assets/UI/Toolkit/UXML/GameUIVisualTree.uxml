<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Template name="AerialControlsMapping" src="project://database/Assets/UI/Toolkit/UXML/AerialControlsMapping.uxml?fileID=9197481963319205126&amp;guid=44473d77220d6fb47b8d9a9fa2cb3d2b&amp;type=3#AerialControlsMapping"/>
    <ui:Template name="CharacterControlsMapping" src="project://database/Assets/UI/Toolkit/UXML/CharacterControlsMapping.uxml?fileID=9197481963319205126&amp;guid=9d1997096be6e754ea996ec8050acd49&amp;type=3#CharacterControlsMapping"/>
    <ui:Template name="PlayerVisualTree" src="project://database/Assets/UI/Toolkit/UXML/PlayerVisualTree.uxml?fileID=9197481963319205126&amp;guid=1f3fc5bf0d1b2d545b5129799909dbff&amp;type=3#PlayerVisualTree"/>
    <Style src="project://database/Assets/UI/Toolkit/USS/MayritStyle.uss?fileID=7433441132597879392&amp;guid=7a6c8e791557401438e2762dac509247&amp;type=3#MayritStyle"/>
    <ui:VisualElement name="MainMenu" style="-unity-text-align: middle-center; flex-grow: 1; justify-content: center; align-self: stretch; display: none; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-color: rgb(17, 17, 17); flex-direction: row;">
        <ui:VisualElement name="MainMenuBgImage" style="background-image: url(&quot;project://database/Assets/Imports/Background%201.png?fileID=2800000&amp;guid=45191b62e64522742a762b45f9987ec1&amp;type=3#Background 1&quot;); position: absolute; top: -10px; left: -633px; right: auto; bottom: auto; width: 2567px; height: 1473px;"/>
        <ui:VisualElement name="Menu" style="flex-grow: 1; flex-direction: row; justify-content: flex-end;">
            <ui:VisualElement name="LogoArea" style="flex-grow: 1; position: absolute; align-self: flex-start; left: 0; top: 0; height: 215px; width: 1220px; justify-content: flex-end;">
                <ui:VisualElement name="Logo" style="height: 100px;">
                    <ui:Label text="MAYRIT" enable-rich-text="true" class="title"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="RightPanel" class="contextualPanel" style="position: relative; flex-shrink: 0; flex-grow: 0; display: flex;">
                <ui:VisualElement name="BlurBg" class="contextualPanelBlurBg"/>
                <ui:VisualElement name="TitleArea" style="justify-content: center; align-self: center; height: 300px;">
                    <ui:Label text="Menú principal" name="Title" class="subtitle"/>
                </ui:VisualElement>
                <ui:VisualElement name="Buttons" style="display: flex; margin-top: 50px;">
                    <ui:Button text="Cargar partida" name="LoadGameButton" class="button highlighted"/>
                    <ui:Button text="Nueva partida" name="NewGameButton" class="button"/>
                    <ui:Button text="Ajustes" name="SettingsButton" class="button"/>
                    <ui:Button text="Créditos" name="CreditsButton" class="button" style="position: relative; margin-top: 100px;"/>
                    <ui:Button text="Salir" name="QuitButton" class="button" style="margin-top: 15px;"/>
                </ui:VisualElement>
                <ui:VisualElement name="NewGameWarning" style="display: none; position: absolute; align-self: center; top: 450px;">
                    <ui:VisualElement name="Pop-up" class="section" style="flex-grow: 0; width: 490px; height: 300px; justify-content: space-between; align-self: center; display: flex;">
                        <ui:VisualElement style="justify-content: space-between; align-self: stretch; padding-top: 35px; padding-right: 40px; padding-bottom: 0; padding-left: 40px;">
                            <ui:Label text="¿Seguro que quieres empezar una nueva partida?" class="subHeader" style="margin-top: 0; margin-right: 0; margin-bottom: 15px; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-text-align: upper-center;"/>
                            <ui:Label text="Se borrará la partida anterior." class="text" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-text-align: middle-center;"/>
                        </ui:VisualElement>
                        <ui:VisualElement style="justify-content: space-between; align-self: stretch; flex-direction: row;">
                            <ui:Button text="Sí" name="ConfirmNewGameButton" class="button mediumButton" style="width: 180px; position: relative;"/>
                            <ui:Button text="No" name="CancelNewGameButton" class="button mediumButton highlighted" style="width: 180px; position: relative;"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
    <ui:VisualElement name="HUD" picking-mode="Ignore" style="flex-grow: 1; position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: none; flex-direction: row-reverse;">
        <ui:VisualElement name="AerialHUD" enabled="true" picking-mode="Ignore" style="flex-direction: row; display: none; flex-grow: 1; position: absolute; top: 0; left: 0; bottom: 0; right: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-top: 30px; margin-right: 30px; margin-bottom: 30px; margin-left: 30px;">
            <ui:VisualElement name="Left" picking-mode="Ignore" style="flex-grow: 1;">
                <ui:VisualElement name="Up" style="flex-direction: column; position: absolute; top: 0; left: 0;"/>
                <ui:VisualElement name="Down" style="flex-grow: 1; position: absolute; left: 0; bottom: 0; align-items: flex-start;">
                    <ui:VisualElement name="ControlsMapping" style="flex-grow: 1; margin-bottom: 40px; display: flex;">
                        <ui:VisualElement name="BlurBg" class="smallButtonBlurBg"/>
                        <ui:Instance template="AerialControlsMapping" name="AerialControlsMapping"/>
                    </ui:VisualElement>
                    <ui:VisualElement name="PauseAndModernSwitch" style="align-items: flex-start; flex-direction: row;">
                        <ui:VisualElement name="BlurBg" class="smallButtonBlurBg"/>
                        <ui:VisualElement name="TutorialPauseButton" style="align-self: center;">
                            <ui:Button text="| |" name="PauseButton" class="button smallButton" style="align-self: flex-start; position: relative; flex-direction: row;"/>
                            <ui:Label text="[Esc]" class="HUDtext" style="top: -30px; position: absolute; align-self: center;"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="TutorialModernVisualizationSwitch" style="align-self: center; display: flex;">
                            <Switch text="Edificios modernos" value="false" name="ModernVisualizationSwitch" style="display: flex; margin-right: 20px; margin-left: 15px;"/>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="Right" picking-mode="Ignore" style="flex-grow: 1; display: flex;">
                <ui:VisualElement name="Up" style="top: 0; right: 0; position: absolute; display: flex; flex-direction: row-reverse;"/>
                <ui:VisualElement name="Down" style="position: absolute; left: auto; bottom: 0; right: 0;"/>
            </ui:VisualElement>
            <ui:VisualElement name="TutorialMilestoneArea" picking-mode="Ignore" style="position: absolute; bottom: 0; left: 0; right: 0; justify-content: flex-end; display: flex;">
                <ui:VisualElement name="MilestoneArea" style="flex-direction: row; align-self: center;">
                    <ui:VisualElement name="BlurBg" class="smallButtonBlurBg" style="display: flex;"/>
                    <ui:VisualElement name="Buttons" style="flex-grow: 1; flex-direction: row; display: flex; align-self: center; justify-content: center;">
                        <ui:VisualElement name="TutorialPreviousMilestoneButton" style="flex-grow: 1; justify-content: center;">
                            <ui:Button name="PreviousMilestoneButton" class="smallButton button" style="position: relative; background-image: url(&quot;project://database/Assets/UI/Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=-1008301579157283121&amp;guid=2196264947afaa74a8b087d37850e618&amp;type=3#arrow-left@2x&quot;); align-self: center; margin-right: 7.5px; padding-top: 0; display: flex;"/>
                        </ui:VisualElement>
                        <ui:VisualElement name="TutorialMilestoneInfoButton" style="flex-grow: 1;">
                            <ui:Button name="MilestoneInfoButton" class="button" style="align-self: center; justify-content: center; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; min-width: 250px; width: auto;">
                                <ui:Label text="Nombre de hito" name="Name" enabled="true" picking-mode="Ignore" class="subHeader" style="height: 30px; -unity-text-align: middle-center; padding-top: 5px;"/>
                                <ui:Label text="Fecha" name="Date" enabled="true" picking-mode="Ignore" class="text" style="height: 30px; -unity-text-align: middle-center; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 7px;"/>
                            </ui:Button>
                        </ui:VisualElement>
                        <ui:VisualElement name="TutorialNextMilestoneButton" style="flex-grow: 1; display: flex; justify-content: center;">
                            <ui:Button name="NextMilestoneButton" text="" class="button highlighted smallButton" style="position: relative; margin-left: 7.5px; padding-left: 0; align-self: center; padding-top: 0;">
                                <ui:Image source="project://database/Assets/UI/Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=-1087164816274819069&amp;guid=2196264947afaa74a8b087d37850e618&amp;type=3#arrow-right@2x" name="RightArrow" style="position: absolute; top: -7px; left: 0; right: auto; bottom: -7px; width: 60px;"/>
                            </ui:Button>
                        </ui:VisualElement>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="TutorialPlayerFollower" picking-mode="Ignore" style="flex-grow: 1; position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
                <ui:VisualElement name="PlayerFollower" style="flex-grow: 1; width: 60px; height: 60px; position: absolute; top: 1100px; left: auto; display: flex;">
                    <ui:VisualElement name="Angle" style="justify-content: space-between; align-self: stretch; background-color: rgba(37, 41, 58, 0.59); border-top-left-radius: 160px; border-top-right-radius: 160px; border-bottom-right-radius: 160px; border-bottom-left-radius: 160px; border-top-width: 3px; border-right-width: 3px; border-bottom-width: 3px; border-left-width: 3px; border-left-color: rgb(64, 73, 118); border-right-color: rgb(64, 73, 118); border-top-color: rgb(64, 73, 118); border-bottom-color: rgb(64, 73, 118); flex-grow: 1; position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
                        <ui:VisualElement style="background-image: url(&quot;project://database/Assets/UI/Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=6936960519852013934&amp;guid=2196264947afaa74a8b087d37850e618&amp;type=3#arrow-up@2x&quot;); top: -40px; -unity-background-image-tint-color: rgb(64, 73, 118); width: 40px; height: 40px; right: 0; left: 0; align-self: center;"/>
                    </ui:VisualElement>
                    <ui:VisualElement name="Icon" style="width: 30px; height: 40px; position: absolute; top: 13px; left: 15px; right: 16px; bottom: 16px;">
                        <ui:Label text="." name="Label" style="color: rgb(255, 255, 255); font-size: 70px; -unity-text-align: middle-center; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; -unity-font-style: bold; position: absolute; top: -55px; left: 0; right: 0; bottom: auto;"/>
                        <ui:VisualElement style="background-image: url(&quot;project://database/Assets/UI/Toolkit/UnityThemes/UnityDefaultRuntimeTheme.tss?fileID=-1304905567622442630&amp;guid=2196264947afaa74a8b087d37850e618&amp;type=3#arrow-down@2x&quot;); width: 60px; height: 40px; align-self: center; position: absolute; top: 5px; left: auto;"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="TutorialSteps" picking-mode="Ignore" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; justify-content: center; display: flex;">
                <ui:VisualElement name="Welcome" style="position: absolute; flex-direction: row; display: none; width: 600px; padding-top: 20px; padding-right: 20px; padding-bottom: 20px; padding-left: 20px; left: auto; right: auto; bottom: 100px; top: auto; align-self: center;">
                    <ui:VisualElement name="Bg" class="tutorialBlurBg" style="flex-grow: 1; display: flex;"/>
                    <ui:VisualElement style="flex-grow: 1; align-self: auto; justify-content: center; width: 300px;">
                        <ui:Label text="¡Bienvenido!" name="Subheader" class="subHeader" style="margin-top: 0; -unity-text-align: upper-center;"/>
                        <ui:Label text="En esta experiencia viajarás entre los diferentes Hitos que marcaron la historia de Madrid: desde la fundación de Mayrit en el s.X hasta la construcción de la muralla cristiana en el s.XIII.&#10;Pulsa [Enter] para comenzar el tutorial." name="Text" class="text" style="-unity-text-align: middle-center;"/>
                    </ui:VisualElement>
                </ui:VisualElement>
                <ui:VisualElement name="ZoomOut" style="position: absolute; flex-direction: row; display: none; width: 500px; padding-top: 20px; padding-right: 20px; padding-bottom: 20px; padding-left: 20px; left: auto; right: auto; bottom: 100px; top: auto; align-self: center;">
                    <ui:VisualElement name="Bg" class="tutorialBlurBg" style="flex-grow: 1; display: flex;"/>
                    <ui:VisualElement style="flex-grow: 1; align-self: auto; justify-content: center; width: 300px;">
                        <ui:Label text="Alejar cámara" name="Subheader" class="subHeader" style="margin-top: 0; -unity-text-align: upper-center;"/>
                        <ui:Label text="Deliza hacia abajo la rueda del ratón." name="Text" class="text" style="-unity-text-align: middle-center;"/>
                    </ui:VisualElement>
                    <ui:VisualElement name="Mouse" style="margin-left: 20px; margin-right: 20px; -unity-font-definition: url(&quot;project://database/Assets/TextMesh%20Pro/Fonts/ElMessiri-Regular.ttf?fileID=12800000&amp;guid=c566193adbf5c6d44a80f316aea394d1&amp;type=3#ElMessiri-Regular&quot;);">
                        <ui:VisualElement name="Design" style="flex-grow: 0; background-color: rgba(229, 229, 229, 0.29); position: relative; border-top-left-radius: 20px; border-top-right-radius: 20px; border-bottom-right-radius: 20px; border-bottom-left-radius: 20px; border-left-color: rgba(229, 229, 229, 0.29); border-right-color: rgba(229, 229, 229, 0.29); border-top-color: rgba(229, 229, 229, 0.29); border-bottom-color: rgba(229, 229, 229, 0.29); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; flex-direction: row; width: 100px; height: 165px; justify-content: center;">
                            <ui:VisualElement name="Left" style="flex-grow: 1; background-color: rgba(183, 183, 183, 0.29); border-left-color: rgba(229, 229, 229, 0.29); border-right-color: rgba(229, 229, 229, 0.29); border-top-color: rgba(229, 229, 229, 0.29); border-bottom-color: rgba(229, 229, 229, 0.29); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 15px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; align-self: stretch; justify-content: space-around; align-items: center; height: 50%;"/>
                            <ui:VisualElement name="Middle" style="flex-grow: 0; background-color: rgba(183, 183, 183, 0.29); border-left-color: rgba(229, 229, 229, 0.29); border-right-color: rgba(229, 229, 229, 0.29); border-top-color: rgba(229, 229, 229, 0.29); border-bottom-color: rgba(229, 229, 229, 0.29); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; height: 40%; top: 5px; margin-top: 1px; margin-right: 1px; margin-bottom: 1px; margin-left: 1px; justify-content: space-between; align-items: center; align-self: stretch; width: 20%;"/>
                            <ui:VisualElement name="Right" style="flex-grow: 1; background-color: rgba(183, 183, 183, 0.29); border-left-color: rgba(229, 229, 229, 0.29); border-right-color: rgba(229, 229, 229, 0.29); border-top-color: rgba(229, 229, 229, 0.29); border-bottom-color: rgba(229, 229, 229, 0.29); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 5px; border-top-right-radius: 15px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; height: 50%;"/>
                            <ui:VisualElement name="Labels" style="align-self: stretch; align-items: stretch; justify-content: space-between; position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
                                <ui:Label text="Seleccionar" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; color: rgb(255, 255, 255); -unity-text-align: middle-center; white-space: normal; -unity-font-style: normal; font-size: 14px; position: absolute; bottom: auto; left: -40px; right: auto; top: 55px; display: none;"/>
                                <ui:Label text="&#10;Zoom&#10;&lt;b&gt;↓&lt;/b&gt;" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; color: rgb(255, 255, 255); -unity-text-align: middle-center; white-space: normal; -unity-font-style: normal; font-size: 14px; position: absolute; bottom: auto; left: 0; right: 0; top: 10px;"/>
                                <ui:Label text="Orientar" style="margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; color: rgb(255, 255, 255); -unity-text-align: middle-center; white-space: normal; -unity-font-style: normal; font-size: 14px; position: absolute; top: 55px; left: 62px; display: none;"/>
                            </ui:VisualElement>
